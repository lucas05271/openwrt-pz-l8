From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CrazyBoyFeng <CrazyBoyFeng@users.noreply.github.com>
Date: Wed, 21 May 2026 00:00:00 +0800
Subject: [PATCH] mtd: spinand: Add support for FMSH FM25LS01

Add support for FM25LS01 SPI NAND flash from Fudan Micro (FMSH).
This chip is used in later revisions (V2) of the CMCC PZ-L8 router,
replacing the ESMT F50D1G41LB.

FM25LS01 specifications:
- Capacity: 128MiB (1Gb)
- Page size: 2048 bytes
- OOB size: 128 bytes
- Pages per block: 64
- Blocks per die: 1024
- ECC requirement: 1 bit per 512 bytes (software ECC)
- No Quad Enable bit

Based on ImmortalWrt patch:
  400-mtd-spinand-Support-fmsh.patch
---
 drivers/mtd/nand/spi/fmsh.c | 40 ++++++++++++++++++++++++++++++++++++++++
 1 file changed, 40 insertions(+)

--- a/drivers/mtd/nand/spi/fmsh.c
+++ b/drivers/mtd/nand/spi/fmsh.c
@@ -52,6 +52,30 @@ static int fm25s01a_ooblayout_free(struc
 	return 0;
 }

+static int fm25ls01_ooblayout_ecc(struct mtd_info *mtd, int section,
+				   struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+
+	region->offset = 64;
+	region->length = 64;
+
+	return 0;
+}
+
+static int fm25ls01_ooblayout_free(struct mtd_info *mtd, int section,
+				   struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+
+	region->offset = 2;
+	region->length = 62;
+
+	return 0;
+}
+
 static int fm25s01bi3_ecc_get_status(struct spinand_device *spinand,
 				     u8 status)
 {
@@ -107,6 +131,11 @@ static const struct mtd_ooblayout_ops fm
 	.free = fm25s01a_ooblayout_free,
 };

+static const struct mtd_ooblayout_ops fm25ls01_ooblayout = {
+	.ecc = fm25ls01_ooblayout_ecc,
+	.free = fm25ls01_ooblayout_free,
+};
+
 static const struct mtd_ooblayout_ops fm25s01bi3_ooblayout = {
 	.ecc = fm25s01bi3_ooblayout_ecc,
 	.free = fm25s01bi3_ooblayout_free,
@@ -122,6 +151,15 @@ static const struct spinand_info fmsh_sp
 					      &update_cache_variants),
 		     0,
 		     SPINAND_ECCINFO(&fm25s01a_ooblayout, NULL)),
+	SPINAND_INFO("FM25LS01",
+		     SPINAND_ID(SPINAND_READID_METHOD_OPCODE_DUMMY, 0xA5),
+		     NAND_MEMORG(1, 2048, 128, 64, 1024, 20, 1, 1, 1),
+		     NAND_ECCREQ(1, 512),
+		     SPINAND_INFO_OP_VARIANTS(&read_cache_variants,
+					      &write_cache_variants,
+					      &update_cache_variants),
+		     0,
+		     SPINAND_ECCINFO(&fm25ls01_ooblayout, NULL)),
 	SPINAND_INFO("FM25S01BI3",
 		     SPINAND_ID(SPINAND_READID_METHOD_OPCODE_DUMMY, 0xd4),
 		     NAND_MEMORG(1, 2048, 128, 64, 1024, 20, 1, 1, 1),
